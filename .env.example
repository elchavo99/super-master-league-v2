# ⭐ COPIE ESTE ARQUIVO E RENOMEIE PARA .env.local ⭐

# Supabase Configuration
# Pegue esses valores em: supabase.com → seu projeto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=seu-anon-key-aqui

# Google OAuth Configuration (opcional - para login com Google)
# Pegue em: console.cloud.google.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=seu-google-client-id
GOOGLE_CLIENT_SECRET=seu-google-client-secret

# NBA Stats API Configuration
# Você pode usar ESPN API (gratuita) ou outra fonte
NBA_STATS_API_KEY=opcional
